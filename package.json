{
  "name": "menny",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "bun --watch server/index.ts",
    "dev:admin": "vite --config admin/vite.config.ts",
    "dev:all": "bun run dev & bun run dev:server & bun run dev:admin",
    "build": "tsr generate && vite build",
    "build:admin": "vite build --config admin/vite.config.ts",
    "build:all": "bun run build && bun run build:admin",
    "typecheck": "tsr generate && cd admin && bunx @tanstack/router-cli generate && cd .. && tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:generate": "bunx drizzle-kit generate --config server/drizzle.config.ts",
    "db:migrate": "bunx drizzle-kit migrate --config server/drizzle.config.ts",
    "db:studio": "bunx drizzle-kit studio --config server/drizzle.config.ts"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/router-plugin": "^1.168.18",
    "better-auth": "^1.6.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "lucide-react": "^1.17.0",
    "minio": "^8.0.7",
    "nodemailer": "^9.0.0",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-cli": "^1.167.17",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.12.3",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
